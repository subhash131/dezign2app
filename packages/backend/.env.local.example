
# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-project-name
CONVEX_URL=https://your-project.convex.cloud
CONVEX_SITE_URL=https://your-project.convex.site

# Clerk Authentication
CLERK_ISSUER_URL=https://your-clerk-domain.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_...

# Embeddings server
EMBEDDING_384_MODEL_URL=https://your-embeddings-server.com

# Creem Payments
CREEM_SUBSCRIPTION_WEBHOOK_SECRET=your_webhook_secret_here

# Workflow Engine
WORKFLOW_ENGINE_BASE_URL=http://localhost:3001
SYSTEM_CORE_SECRET=sk_core_...

# Secrets Management
WORKFLOW_SECRETS_MASTER_KEY=your_master_key_here